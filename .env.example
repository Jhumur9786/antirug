# AntiRug Environment Configuration
# Copy this file to .env and fill in values as needed.

# Server port (Railway sets this automatically)
PORT=3000

# Python command (use "python" if python3 is not available)
PYTHON_CMD=python3

# Timeout for the Python token scanner (ms)
SCANNER_TIMEOUT_MS=30000

# Timeout for the full pipeline (ms)
PIPELINE_TIMEOUT_MS=60000

# LLM provider for AI-enhanced analysis.
# Groq is supported through its OpenAI-compatible endpoint.
GROQ_API_KEY=your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=openai/gpt-oss-120b

# Optional fallback if you prefer OpenAI directly instead of Groq.
# OPENAI_API_KEY=your_openai_api_key_here
